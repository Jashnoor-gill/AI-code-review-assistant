# Copy this file to .env and fill values for local development

# API token required to call protected endpoints (set REQUIRE to true to enforce)
AI_CODE_REVIEW_TOKEN=
AI_CODE_REVIEW_REQUIRE_API_TOKEN=false

# Database and server
AI_CODE_REVIEW_DATA=./data
AI_CODE_REVIEW_HOST=127.0.0.1
AI_CODE_REVIEW_PORT=8000

# OpenAI (if using OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Hugging Face (if using HF Inference or hosted models)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
# Optional override if you use a different inference host
HUGGINGFACE_API_BASE=https://api-inference.huggingface.co/models

# Local Llama model (ggml path)
LLAMA_MODEL_PATH=

# VCS tokens for posting comments (use least-privilege tokens)
GITHUB_TOKEN=
GITLAB_TOKEN=

# Webhook secrets (used to validate incoming webhook requests)
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=

# Optional: override storage path for reviews
# AI_CODE_REVIEW_DATA=/var/lib/ai-code-review/data
